# Public site URL (no trailing slash). Used for canonical URLs, OG tags, RSS, sitemap.
NEXT_PUBLIC_SITE_URL=https://nonslopai.com

# listmonk — newsletter signup, read by the Next.js app. LISTMONK_URL is the
# base URL of the listmonk instance (e.g. https://news.nonslopai.com, or
# http://localhost:9000 for the local docker-compose stack).
# LISTMONK_LIST_ID is the numeric ID (not UUID — the admin create-subscriber
# API only reads numeric list IDs) of the double opt-in list to subscribe
# people into — find it in listmonk's admin UI under Lists.
LISTMONK_URL=
LISTMONK_LIST_ID=
# API credentials for a listmonk user of type "API", scoped to a role with
# only subscribers:manage + tx:send permissions (Settings > Users).
# Needed because the public subscription endpoint can't set attribs, and to
# send the welcome transactional email on confirm.
LISTMONK_API_USER=
LISTMONK_API_KEY=
# Numeric ID of the "Welcome" transactional template (Campaigns > Templates,
# type "Transactional") sent right after a subscriber double opt-in confirms.
LISTMONK_WELCOME_TEMPLATE_ID=

# listmonk — container config, read by docker-compose.yml (`docker compose
# up`). Defaults are fine for local dev as-is; set real values in the .env
# that lives on the production server (never committed).
#
# COMPOSE_PROFILES picks which extra service comes up alongside app+db:
#   dev  -> Mailpit (local mail catcher, UI at http://localhost:8025)
#   prod -> Caddy (TLS termination for LISTMONK_HOSTNAME)
COMPOSE_PROFILES=dev
LISTMONK_DB_PASSWORD=listmonk
LISTMONK_ADMIN_USER=
LISTMONK_ADMIN_PASSWORD=
# Public domain in prod (news.nonslopai.com — serves both the listmonk app
# and the email sending identity) — used by Caddy to request a TLS cert.
# Leave unset locally; the prod profile that needs it isn't active in dev.
LISTMONK_HOSTNAME=

# MinIO (dev profile only) — S3-compatible media storage, mirrors prod's
# Cloudflare R2 setup. Defaults below are fine for local dev; prod uses real
# R2 credentials configured directly in listmonk's Settings > Media, not
# these — MinIO never runs in the prod profile.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=nonslop-dev
# In listmonk's Settings > Media, once MinIO is up:
#   Provider: s3
#   S3 URL: http://minio:9000
#   S3 public URL: http://localhost:9002/nonslop-dev  (must include the
#     bucket name — listmonk appends only the object key, not the bucket)
#   Bucket: nonslop-dev, Bucket type: public
#   Access/secret key: same as MINIO_ROOT_USER/PASSWORD above
